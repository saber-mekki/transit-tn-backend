# ─── DATABASE ────────────────────────────────────
# Local PostgreSQL:
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/transit_tn"

# Supabase (cloud option):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Railway / Render (they give you this URL automatically):
# DATABASE_URL="postgresql://..."

# ─── JWT ─────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="transit-tn-super-secret-jwt-key-change-me-in-production"

# ─── SERVER ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── FRONTEND URL (for CORS) ─────────────────────
FRONTEND_URL=http://localhost:5173
