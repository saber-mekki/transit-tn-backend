datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

// ─── ENUMS ───────────────────────────────────────
enum UserRole {
  USER
  OPERATOR
  ADMIN
}

enum TripStatus {
  ACTIVE
  FULL
  COMPLETED
}

enum TransportType {
  LOUAGE
  BUS
  TRANSPORTER
}

// ─── MODELS ──────────────────────────────────────
model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String?   @unique
  phone       String?
  bio         String?
  pushToken   String?
  password    String
  displayName String
  role        UserRole  @default(USER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  operatorRatings OperatorRating[] @relation("OperatorRatings")
  givenRatings    OperatorRating[] @relation("UserRatings")
  shipments       Shipment[]       @relation("OperatorShipments")
  expenses        Expense[]        @relation("OperatorExpenses")
  trips       Trip[]
  notifications Notification[]
}

model Station {
  id                String       @id @default(cuid())
  name              String
  city              String
  lat               Float
  lng               Float
  createdAt         DateTime     @default(now())
  louageTrips       LouageTrip[] @relation("LouageStation")
  busDepartureTrips BusTrip[]    @relation("DepartureStation")
  busArrivalTrips   BusTrip[]    @relation("ArrivalStation")
}

model Trip {
  id              String           @id @default(cuid())
  type            TransportType
  operator        User             @relation(fields: [operatorId], references: [id])
  operatorId      String
  operatorName    String
  fromCity        String
  toCity          String
  departureTime   DateTime
  arrivalTime     DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  status          TripStatus       @default(ACTIVE)
  completedAt     DateTime?
  ratings         Rating[]
  shipments       Shipment[]
  reservations    Reservation[]
  expenses        Expense[]
  louageTrip      LouageTrip?
  busTrip         BusTrip?
  transporterTrip TransporterTrip?
}

model LouageTrip {
  id                String   @id @default(cuid())
  trip              Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId            String   @unique
  station           Station? @relation("LouageStation", fields: [stationId], references: [id])
  stationId         String?
  customStationName String?
  price             Float
  totalSeats        Int      @default(8)
  availableSeats    Int
  isFull            Boolean  @default(false)
  vehicleNumber     String?
  contactInfo       String?
}

model BusTrip {
  id                         String   @id @default(cuid())
  trip                       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId                     String   @unique
  departureStation           Station? @relation("DepartureStation", fields: [departureStationId], references: [id])
  departureStationId         String?
  arrivalStation             Station? @relation("ArrivalStation", fields: [arrivalStationId], references: [id])
  arrivalStationId           String?
  customDepartureStationName String?
  customArrivalStationName   String?
  price                      Float
  totalSeats                 Int
  availableSeats             Int
}

model TransporterTrip {
  id             String   @id @default(cuid())
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId         String   @unique
  contactInfo    String
  vehicleType    String
  availableSpace String
  eta            String
  pricePerKg     Float?
  route          String[]
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String?
  subtitle  String?
  link      String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Rating {
  id          String   @id @default(cuid())
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId      String
  userId      String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())
}

model OperatorRating {
  id          String   @id @default(cuid())
  operator    User     @relation("OperatorRatings", fields: [operatorId], references: [id], onDelete: Cascade)
  operatorId  String
  user        User     @relation("UserRatings", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())
}

model Reservation {
  id          String   @id @default(cuid())
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId      String
  userId      String
  userName    String
  userPhone   String
  note        String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id         String   @id @default(cuid())
  operator   User     @relation("OperatorExpenses", fields: [operatorId], references: [id], onDelete: Cascade)
  operatorId String
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  tripId     String?
  label      String
  category   String   @default("OTHER")
  amount     Float
  createdAt  DateTime @default(now())
}

model Shipment {
  id              String   @id @default(cuid())
  trackingNumber  String   @unique
  operator        User     @relation("OperatorShipments", fields: [operatorId], references: [id], onDelete: Cascade)
  operatorId      String
  trip            Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  tripId          String?
  senderName      String
  senderPhone     String
  receiverName    String
  receiverPhone   String
  description     String
  fromCity        String
  toCity          String
  price           Float?
  weight          Float?
  status          String   @default("RECEIVED")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
